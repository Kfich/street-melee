# ── Client environment variables ──────────────────────────────────────────────
# Vite exposes variables prefixed with VITE_ to the browser bundle.
# Copy this file to .env.production.local (gitignored) and fill in your values,
# OR set these directly in your hosting platform's dashboard (e.g. Netlify).

# Socket.io multiplayer server URL.
# Development default (http://localhost:3001) is built into the code, so this
# file is only needed when deploying to production.
VITE_SERVER_URL=https://your-server.up.railway.app
