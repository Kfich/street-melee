{
  "name": "street-melee",
  "version": "1.0.0",
  "description": "A Streets of Rage inspired beat 'em up game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "server:dev": "tsx src/server/index.ts",
    "server:build": "tsc -p tsconfig.server.json && node dist/server/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": ["game", "beat-em-up", "multiplayer"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "phaser": "^3.80.1",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@vitest/ui": "^1.0.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jsdom": "^23.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  }
}

