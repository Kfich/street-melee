{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": "./dist/server",
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src/server/**/*"],
  "exclude": ["node_modules", "dist"]
}

